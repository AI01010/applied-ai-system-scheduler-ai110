# Copy to .env and fill in at least ONE of the keys below.
# Without any key, the system runs in deterministic-template fallback mode —
# retrieval still works, but no LLM-generated explanations.
#
# Provider selection order at runtime:
#   1. Gemini (recommended — free tier available)
#   2. Anthropic (paid)
#   3. Template fallback

# Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude — paid; get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
